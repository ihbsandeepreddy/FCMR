# Normalize line endings to LF across all platforms
* text=auto

# Explicitly set LF for code files
*.py text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=ts
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.md text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.zip binary
*.exe binary
*.dll binary
