# SanGir Automations — Production Environment
# Use this template for production deployments.

APP_ENV=production

FCMR_BACKEND_PORT=8765

LOG_LEVEL=WARNING

FCMR_FUZZY_MATCH_THRESHOLD=0.6

# CRITICAL: Generate a strong, unique salt. Example command:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
FCMR_AADHAAR_HASH_SALT=REPLACE_WITH_STRONG_SECRET_SALT_32_CHARS_MIN

# Persistent data location (AppData on Windows, ~/.sangir on Linux/macOS if not frozen)
# FCMR_DATA_DIR=C:\Users\YourName\AppData\Local\SanGirAutomations\data

AUTO_UPDATE_ENABLED=true
