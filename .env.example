# SanGir Automations — Environment Configuration Example
# Copy to .env and customize for your deployment.
# NEVER commit real .env files to git.

# Application environment (dev | production)
APP_ENV=development

# Backend network port (dev: 8000, desktop: 8765)
FCMR_BACKEND_PORT=8000

# Logging level (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO

# Column mapping fuzzy match threshold (0.0–1.0)
FCMR_FUZZY_MATCH_THRESHOLD=0.6

# Aadhaar hashing salt (keep SECRET; random 32+ chars)
FCMR_AADHAAR_HASH_SALT=your-secret-salt-here-change-in-production

# Data directory (absolute path; leave empty to use default)
# FCMR_DATA_DIR=/path/to/persistent/data

# Auto-update enabled (for desktop app)
AUTO_UPDATE_ENABLED=true
