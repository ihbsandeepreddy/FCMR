# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.venv/
venv/
*.egg

# Allow PyInstaller spec files
!build/*.spec

# Data — never commit user data or generated outputs
data/
*.parquet
*.csv

# Allow bundled reference data shipped with the package
!fcmr_core/reference/*.parquet
!fcmr_core/reference/*.csv

# Env / secrets
.env
.env.*
# But DO commit example templates
!.env.example
!.env.production.example

# Node / Electron
node_modules/
dist/
electron/node_modules/

# IDEs
.vscode/
.idea/
*.iml

# OS
.DS_Store
Thumbs.db

# Testing / coverage
.pytest_cache/
.coverage
htmlcov/

# Ruff / Black cache
.ruff_cache/

# Server logs
uvicorn.log
uvicorn_err.log
*.log
