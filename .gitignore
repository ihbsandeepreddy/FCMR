# Data — never commit user data or generated outputs
data/
*.parquet
*.csv

# Allow bundled reference data shipped with the package
!fcmr_core/reference/*.parquet
!fcmr_core/reference/*.csv

# Env / secrets
.env
.env.*

# IDEs
.vscode/
.idea/
*.iml

# OS
.DS_Store
Thumbs.db

# Testing / coverage
.pytest_cache/
.coverage
htmlcov/

# Ruff / Black cache
.ruff_cache/

# Server logs
uvicorn.log
uvicorn_err.log
*.log
